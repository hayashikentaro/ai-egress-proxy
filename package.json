{
  "name": "ai-egress-proxy",
  "version": "0.0.0",
  "description": "Minimal TypeScript egress proxy for outbound AI provider calls.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "smoke:forward": "bash scripts/smoke-forward-proxy.sh",
    "start": "node dist/src/index.js",
    "test": "npm run build && node --test dist/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "ai",
    "egress",
    "proxy",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
